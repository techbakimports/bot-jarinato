# ────────────────────────────────────────────────────────────────────────────
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
# cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ── Evolution API ─────────────────────────────────────────────────────────────
# URL pública onde a Evolution API ficará acessível (sem barra no final)
# Em desenvolvimento local: http://localhost:8080
# Em produção: https://api.seudominio.com
EVOLUTION_SERVER_URL=http://localhost:8080

# Chave de autenticação da Evolution API (gere uma string aleatória segura)
# Exemplo: openssl rand -hex 32
EVOLUTION_API_KEY=sua_chave_secreta_aqui

# ── Typebot ───────────────────────────────────────────────────────────────────
# URL do painel admin do Typebot
TYPEBOT_BUILDER_URL=http://localhost:3001

# URL pública do viewer (onde os flows são executados)
TYPEBOT_VIEWER_URL=http://localhost:3002

# Secret para assinar os JWTs do Typebot (gere com: openssl rand -base64 32)
TYPEBOT_SECRET=seu_typebot_secret_aqui

# E-mail do admin inicial do Typebot
ADMIN_EMAIL=seu@email.com

# ── SMTP (opcional — necessário para o Typebot enviar e-mail de login) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu@gmail.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_FROM=noreply@seudominio.com

# ── Bancos de Dados ───────────────────────────────────────────────────────────
# Senhas dos PostgreSQL (use senhas fortes e diferentes para cada banco)
POSTGRES_EVOLUTION_PASSWORD=senha_evolution_postgres
POSTGRES_TYPEBOT_PASSWORD=senha_typebot_postgres
POSTGRES_APP_PASSWORD=senha_app_postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=senha_redis

# ── Fase 2 — Configuração da Comunicação ──────────────────────────────────────
# Nome da instância WhatsApp na Evolution API (use só letras, números e hífens)
EVOLUTION_INSTANCE_NAME=techbak

# ID público do fluxo no Typebot
# Onde encontrar: Typebot Builder → seu fluxo → Configurações → Geral → Public ID
TYPEBOT_FLOW_ID=

# ── Fase 3 — FastAPI ─────────────────────────────────────────────────────────
# URL onde o FastAPI ficará acessível (sem barra no final)
FASTAPI_URL=http://localhost:8000

# Secret para assinar os JWTs dos atendentes (gere com: openssl rand -hex 32)
JWT_SECRET=seu_jwt_secret_aqui

# ── Fase 4 — Painel de Atendimento ───────────────────────────────────────────
# URL pública do painel (usada no corpo dos e-mails de notificação)
PAINEL_URL=http://localhost

# ── Fase 5 — Integração Odoo (opcional) ──────────────────────────────────────
# Deixar em branco para desabilitar. Quando preenchido, o sistema consulta
# o Odoo automaticamente a cada transbordo para preencher dados do cliente.
ODOO_URL=https://seu-odoo.odoo.com
ODOO_DB=nome_do_banco_odoo
ODOO_USER=usuario@odoo.com
ODOO_PASSWORD=senha_ou_api_key_do_odoo

# ── Fase 5 — Notificações SMTP (opcional) ────────────────────────────────────
# E-mail enviado aos atendentes quando um novo ticket entra na fila.
# Usar variáveis diferentes das do Typebot (SMTP_USER vs SMTP_USERNAME).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=sua_senha_de_app_gmail
SMTP_FROM=noreply@techbak.com
NOTIF_EMAIL_DESTINO=atendentes@seudominio.com
